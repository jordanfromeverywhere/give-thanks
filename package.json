{
  "name": "give-thanks",
  "version": "0.1.0",
  "description": "A CLI for thanking open source maintainers — star repos and post gratitude in GitHub Discussions",
  "type": "module",
  "license": "MIT",
  "author": "Jordan Franznick <cfranznick@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jordanfromeverywhere/give-thanks.git"
  },
  "homepage": "https://github.com/jordanfromeverywhere/give-thanks#readme",
  "bugs": {
    "url": "https://github.com/jordanfromeverywhere/give-thanks/issues"
  },
  "types": "./dist/cli.d.ts",
  "bin": {
    "give-thanks": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "open-source",
    "gratitude",
    "github",
    "cli",
    "oss",
    "thanks",
    "maintainers"
  ],
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@octokit/rest": "^22.0.1",
    "commander": "^14.0.3",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
